# Devcontainer environment — safe defaults, fully isolated.
# WARNING: Do NOT put ANTHROPIC_API_KEY here. Set it in your shell or VS Code settings.
DJANGO_SETTINGS_MODULE=bgc_data_portal.settings
DJANGO_SECRET_KEY=devcontainer-secret-key-not-for-production
DJANGO_DEBUG=True
ADMIN_API_TOKEN=devcontainer-admin-token
PROJECT_USER_TOKEN=devcontainer-project-token

# Database
DATABASE_URL=postgres://bgc_devcontainer:devcontainerpass@db:5432/bgc_devcontainer
POSTGRES_USER=bgc_devcontainer
POSTGRES_PASSWORD=devcontainerpass
POSTGRES_DB=bgc_devcontainer

# Celery
CELERY_BROKER_URL=amqp://guest:guest@rabbitmq:5672/
CELERY_RESULT_BACKEND=redis://redis:6379/0

# Django cache (use DB 1 to avoid collision with Celery result backend)
DJANGO_CACHE_BACKEND=redis://redis:6379/1
