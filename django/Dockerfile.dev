FROM python:3.10-slim

RUN apt-get update && apt-get install -y --no-install-recommends \
    gcc build-essential python3-dev libffi-dev libssl-dev git curl \
    && rm -rf /var/lib/apt/lists/*

# Install Node.js 20 LTS for frontend build
RUN curl -fsSL https://deb.nodesource.com/setup_20.x | bash - \
    && apt-get install -y --no-install-recommends nodejs \
    && rm -rf /var/lib/apt/lists/*

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1

WORKDIR /app

COPY requirements-web.txt requirements-dev.txt ./
RUN pip install --upgrade pip \
    && pip install --no-cache-dir -r requirements-web.txt -r requirements-dev.txt

COPY . .

# Build the React frontend (outputs to /app/static/dashboard/)
WORKDIR /app/frontend
RUN npm ci && npx vite build
WORKDIR /app

EXPOSE 8000

# Django runserver auto-reloads on file changes synced by Skaffold.
# For the Celery worker pod, use Dockerfile.worker.dev instead (includes torch/esm).
CMD ["python", "manage.py", "runserver", "0.0.0.0:8000"]
